{
  "_comment": "Grafana Unified Alerting rule template — per-user rate limit burst admin alert.",
  "_version": "1.0",
  "_last_updated": "2026-05-24T00:00:00+00:00",
  "_ysg_risk": "YSG-RISK-058",
  "apiVersion": 1,
  "groups": [
    {
      "orgId": 1,
      "name": "yashigani-user-ratelimit",
      "folder": "Yashigani Security Alerts",
      "interval": "1m",
      "rules": [
        {
          "uid": "ysg-user-rl-burst-001",
          "title": "Per-User Rate Limit Burst (YSG-RISK-058)",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "queryType": "",
              "relativeTimeRange": {"from": 300, "to": 0},
              "datasourceUid": "${DS_PROMETHEUS}",
              "model": {
                "expr": "increase(yashigani_user_rate_limit_violations_total[5m])",
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "A"
              }
            },
            {
              "refId": "B",
              "queryType": "",
              "relativeTimeRange": {"from": 300, "to": 0},
              "datasourceUid": "__expr__",
              "model": {
                "conditions": [
                  {
                    "evaluator": {"params": [0], "type": "gt"},
                    "operator": {"type": "and"},
                    "query": {"params": ["A"]},
                    "reducer": {"params": [], "type": "sum"},
                    "type": "query"
                  }
                ],
                "datasource": {"type": "__expr__", "uid": "__expr__"},
                "expression": "A",
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "B",
                "type": "classic_conditions"
              }
            },
            {
              "refId": "C",
              "queryType": "",
              "relativeTimeRange": {"from": 300, "to": 0},
              "datasourceUid": "__expr__",
              "model": {
                "conditions": [
                  {
                    "evaluator": {"params": [5], "type": "gt"},
                    "operator": {"type": "and"},
                    "query": {"params": ["B"]},
                    "reducer": {"params": [], "type": "last"},
                    "type": "query"
                  }
                ],
                "datasource": {"type": "__expr__", "uid": "__expr__"},
                "expression": "B",
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "C",
                "type": "classic_conditions"
              }
            }
          ],
          "dashboardUid": "yashigani-ratelimit",
          "panelId": 3,
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "2m",
          "annotations": {
            "summary": "User {{ $labels.user_id_hash }} is breaching the per-user rate limit",
            "description": "Prometheus metric yashigani_user_rate_limit_violations_total shows {{ $value }} breaches in the last 5 minutes for user_id_hash={{ $labels.user_id_hash }}. Configured limit: 100 RPS / 200 burst (YSG-RISK-058). Check audit log for USER_RATE_LIMIT_EXCEEDED events to see the full user identifier (admin-only audit chain). Possible causes: runaway agent loop, misconfigured client, abuse.",
            "runbook_url": "https://docs.yashigani.io/ops/rate-limit-runbook",
            "ysg_risk": "YSG-RISK-058",
            "asvs": "V11.1, OWASP API4:2023"
          },
          "labels": {
            "severity": "warning",
            "team": "ops",
            "component": "gateway",
            "ysg_risk": "YSG-RISK-058"
          },
          "isPaused": false
        }
      ]
    }
  ]
}
