{
  "uid": "yashigani-ratelimit",
  "title": "Yashigani — Rate Limit Status",
  "tags": ["yashigani", "ratelimit"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": {"from": "now-30m", "to": "now"},
  "panels": [
    {
      "id": 1, "type": "gauge", "title": "Adaptive Multiplier (current)",
      "gridPos": {"x":0,"y":0,"w":6,"h":6},
      "targets": [{"expr":"yashigani_ratelimit_adaptive_multiplier","legendFormat":"Multiplier"}],
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"minVizValue":0,"maxVizValue":1},
      "fieldConfig": {"defaults":{"min":0,"max":1,"thresholds":{"steps":[{"color":"red","value":null},{"color":"orange","value":0.3},{"color":"yellow","value":0.6},{"color":"green","value":0.9}]}}}
    },
    {
      "id": 2, "type": "stat", "title": "Effective Global RPS",
      "gridPos": {"x":6,"y":0,"w":6,"h":6},
      "targets": [{"expr":"yashigani_ratelimit_effective_rps{dimension=\"global\"}","legendFormat":"Global RPS"}],
      "options": {"colorMode":"value","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig": {"defaults":{"unit":"reqps"}}
    },
    {
      "id": 3, "type": "stat", "title": "Total Violations (1h)",
      "gridPos": {"x":12,"y":0,"w":6,"h":6},
      "targets": [{"expr":"increase(yashigani_ratelimit_violations_total[1h])","legendFormat":"Violations"}],
      "options": {"colorMode":"background","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig": {"defaults":{"thresholds":{"steps":[{"color":"green","value":null},{"color":"yellow","value":10},{"color":"orange","value":50},{"color":"red","value":200}]}}}
    },
    {
      "id": 4, "type": "stat", "title": "RPI (for context)",
      "gridPos": {"x":18,"y":0,"w":6,"h":6},
      "targets": [{"expr":"yashigani_resource_pressure_index","legendFormat":"RPI"}],
      "options": {"colorMode":"background","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig": {"defaults":{"unit":"percentunit","thresholds":{"steps":[{"color":"green","value":null},{"color":"yellow","value":0.3},{"color":"orange","value":0.6},{"color":"red","value":0.8}]}}}
    },
    {
      "id": 5, "type": "timeseries", "title": "Adaptive Multiplier Over Time",
      "gridPos": {"x":0,"y":6,"w":12,"h":7},
      "targets": [
        {"expr":"yashigani_ratelimit_adaptive_multiplier","legendFormat":"Multiplier"},
        {"expr":"yashigani_resource_pressure_index","legendFormat":"RPI (reference)"}
      ],
      "fieldConfig": {"defaults":{"unit":"percentunit","min":0,"max":1,"custom":{"drawStyle":"line","lineWidth":2,"fillOpacity":5}}}
    },
    {
      "id": 6, "type": "timeseries", "title": "Effective RPS per Dimension",
      "gridPos": {"x":12,"y":6,"w":12,"h":7},
      "targets": [
        {"expr":"yashigani_ratelimit_effective_rps","legendFormat":"{{ dimension }}"}
      ],
      "fieldConfig": {"defaults":{"unit":"reqps","custom":{"drawStyle":"line","lineWidth":2,"fillOpacity":5}}}
    },
    {
      "id": 7, "type": "timeseries", "title": "Violations Rate by Dimension",
      "gridPos": {"x":0,"y":13,"w":12,"h":7},
      "targets": [
        {"expr":"rate(yashigani_ratelimit_violations_total[1m])","legendFormat":"{{ dimension }}"}
      ],
      "fieldConfig": {"defaults":{"custom":{"drawStyle":"bars","lineWidth":1,"fillOpacity":60}}}
    },
    {
      "id": 8, "type": "timeseries", "title": "Violations Cumulative by Dimension (1h window)",
      "gridPos": {"x":12,"y":13,"w":12,"h":7},
      "targets": [
        {"expr":"increase(yashigani_ratelimit_violations_total[1h])","legendFormat":"{{ dimension }}"}
      ],
      "fieldConfig": {"defaults":{"custom":{"drawStyle":"line","lineWidth":2,"fillOpacity":10}}}
    },
    {
      "id": 9, "type": "timeseries", "title": "Multiplier vs Violation Surge Correlation",
      "gridPos": {"x":0,"y":20,"w":12,"h":6},
      "targets": [
        {"expr":"yashigani_ratelimit_adaptive_multiplier","legendFormat":"Multiplier"},
        {"expr":"clamp_max(sum(rate(yashigani_ratelimit_violations_total[1m])) / 10, 1)","legendFormat":"Violation rate (norm.)"}
      ],
      "fieldConfig": {"defaults":{"unit":"percentunit","min":0,"max":1,"custom":{"drawStyle":"line","lineWidth":2,"fillOpacity":5}}}
    },
    {
      "id": 10, "type": "timeseries", "title": "Gateway Deny vs Rate-Limit Split",
      "gridPos": {"x":12,"y":20,"w":12,"h":6},
      "targets": [
        {"expr":"sum(rate(yashigani_gateway_requests_total{action=\"RATE_LIMITED\"}[1m]))","legendFormat":"Rate Limited"},
        {"expr":"sum(rate(yashigani_gateway_requests_total{action=\"DENIED\"}[1m]))","legendFormat":"OPA Denied"}
      ],
      "fieldConfig": {"defaults":{"unit":"reqps","custom":{"drawStyle":"line","lineWidth":2,"fillOpacity":10}}}
    },
    {
      "id": 11, "type": "stat", "title": "Per-IP Effective RPS",
      "gridPos": {"x":0,"y":26,"w":6,"h":4},
      "targets": [{"expr":"yashigani_ratelimit_effective_rps{dimension=\"ip\"}","legendFormat":"Per-IP"}],
      "options": {"colorMode":"value","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig": {"defaults":{"unit":"reqps"}}
    },
    {
      "id": 12, "type": "stat", "title": "Per-Agent Effective RPS",
      "gridPos": {"x":6,"y":26,"w":6,"h":4},
      "targets": [{"expr":"yashigani_ratelimit_effective_rps{dimension=\"agent\"}","legendFormat":"Per-Agent"}],
      "options": {"colorMode":"value","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig": {"defaults":{"unit":"reqps"}}
    },
    {
      "id": 13, "type": "stat", "title": "Per-Session Effective RPS",
      "gridPos": {"x":12,"y":26,"w":6,"h":4},
      "targets": [{"expr":"yashigani_ratelimit_effective_rps{dimension=\"session\"}","legendFormat":"Per-Session"}],
      "options": {"colorMode":"value","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig": {"defaults":{"unit":"reqps"}}
    },
    {
      "id": 14, "type": "stat", "title": "Rate Limit Config Last Updated",
      "gridPos": {"x":18,"y":26,"w":6,"h":4},
      "targets": [{"expr":"yashigani_ratelimit_config_last_updated_timestamp_seconds","legendFormat":"Config updated"}],
      "options": {"colorMode":"value","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig": {"defaults":{"unit":"dateTimeAsLocal"}}
    }
  ]
}
