# Yashigani AppArmor profile — gateway and backoffice services
#
# To load this profile on the host before starting the stack:
#   sudo apparmor_parser -r docker/apparmor/yashigani-gateway
#
# Verify it loaded:
#   sudo apparmor_status | grep yashigani-gateway
#
# Then enable in docker-compose.yml by uncommenting:
#   security_opt: ["apparmor=yashigani-gateway"]
#
# Note: AppArmor must be enabled on the host kernel. Check:
#   cat /sys/module/apparmor/parameters/enabled   # should print Y
# AppArmor is enabled by default on Ubuntu/Debian. RHEL/Fedora use SELinux instead.

#include <tunables/global>

profile yashigani-gateway flags=(attach_disconnected,mediate_deleted) {
  #include <abstractions/base>
  #include <abstractions/nameservice>
  #include <abstractions/openssl>
  #include <abstractions/python>

  # Allow read access to system config
  /etc/ r,
  /etc/** r,
  /usr/ r,
  /usr/** r,
  /lib/ r,
  /lib/** r,
  /lib64/ r,
  /lib64/** r,

  # Application code and assets (read-only)
  /app/ r,
  /app/** r,
  /app/models/** r,

  # Writable data directories (mounted as named volumes or tmpfs)
  /tmp/ rw,
  /tmp/** rw,
  /var/log/yashigani/ rw,
  /var/log/yashigani/** rw,
  /data/audit/ rw,
  /data/audit/** rw,
  /data/bootstrap/ rw,
  /data/bootstrap/** rw,

  # Python runtime
  /usr/local/lib/python*/** r,
  /usr/local/bin/python* ix,
  /usr/local/bin/uvicorn ix,

  # Secrets (read-only)
  /run/secrets/ r,
  /run/secrets/** r,

  # Proc — reads required by Python runtime and health checks
  @{PROC}/sys/kernel/ngroups_max r,
  @{PROC}/sys/kernel/cap_last_cap r,
  @{PROC}/@{pid}/status r,
  @{PROC}/@{pid}/maps r,
  @{PROC}/@{pid}/fd/ r,
  @{PROC}/@{pid}/task/ r,
  @{PROC}/sys/net/core/somaxconn r,

  # Deny dangerous kernel/hardware access
  deny @{PROC}/sys/kernel/modules_disabled w,
  deny /proc/sysrq-trigger w,
  deny /sys/firmware/** w,
  deny /sys/kernel/** w,
  deny /dev/mem r,
  deny /dev/kmem r,
  deny /dev/port r,

  # Network — TCP/UDP and Unix sockets only; no raw packet capture
  network tcp,
  network udp,
  network unix,
  deny network raw,
  deny network packet,
  deny network bluetooth,
  deny network netlink,

  # Capabilities — deny privilege escalation and admin capabilities
  deny capability sys_admin,
  deny capability sys_module,
  deny capability sys_rawio,
  deny capability sys_ptrace,
  deny capability sys_boot,
  deny capability mac_admin,
  deny capability mac_override,
  deny capability net_admin,
  deny capability net_raw,
  deny capability setpcap,

  # ptrace — deny all (prevents container escape via process injection)
  deny ptrace,
  deny ptrace peer=**,

  # Mount — deny (enforced by read_only: true in compose; belt-and-suspenders)
  deny mount,
}
