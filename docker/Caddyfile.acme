# Yashigani — Caddy TLS edge (Let's Encrypt / ACME mode)
# Set YASHIGANI_TLS_DOMAIN in your .env before starting.
# Caddy will auto-obtain and renew the certificate via ACME HTTP-01 or TLS-ALPN-01.
#
# Requirements:
#   - Port 80 and 443 reachable from the internet (HTTP-01 challenge)
#   - Or port 443 reachable (TLS-ALPN-01)
#   - YASHIGANI_TLS_DOMAIN must resolve to this server's public IP
#
# TLS policy: TLS 1.2 minimum, TLS 1.3 preferred.
# Key exchange: hybrid post-quantum (X25519+ML-KEM-768) with X25519 fallback.
# Cipher suites: Caddy defaults (ECDHE + AES-GCM / ChaCha20-Poly1305 only).
# HSTS: max-age 1 year, includeSubDomains.
# OCSP stapling: enabled automatically by Caddy.
#
# ── DDoS / Connection Protection ────────────────────────────────────────────
# These protections work with the standard Caddy image (no extra modules needed).
#
# Connection timeouts:
#   Idle connections closed at 120 s; read timeouts prevent slow-body attacks.
#   Configured in the global options block below.
#
# Request body size:
#   request_body max_size applied globally to every handle block.
#   The application layer enforces an additional 4 MB limit (GatewayConfig).
#
# Full WAF (Coraza/OWASP CRS):
#   Requires a custom Caddy build with the coraza-caddy module.
#   See docker/caddy/Caddyfile.waf for instructions and a reference config.
#   Standard Caddy image does NOT include WAF — this is documented in
#   docs/yashigani_install_config.md Section 26.

{
    # ── Connection timeouts (DoS/slow-loris mitigation) ─────────────────────
    servers {
        timeouts {
            read_body   10s
            read_header 5s
            write       30s
            idle        120s
        }
    }
}

{env.YASHIGANI_TLS_DOMAIN} {
    # ── TLS policy ──────────────────────────────────────────────────────────
    tls {
        protocols tls1.2 tls1.3
        # Hybrid post-quantum key exchange: X25519+ML-KEM-768 preferred,
        # X25519 fallback for clients that don't support ML-KEM.
        # Protects against "Harvest Now, Decrypt Later" (HNDL) attacks.
        curves x25519mlkem768 x25519
    }

    # ── Security headers ────────────────────────────────────────────────────
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "no-referrer"
        -Server
    }

    # ── Request body size limit (OWASP ASVS 4.1.7) ──────────────────────────
    # Hard ceiling at Caddy layer — prevents large-body DoS before the request
    # reaches the application.  Application layer enforces a tighter 4 MB limit.
    request_body {
        max_size 10MB
    }

    # ── Gateway health check — /healthz ──────────────────────────────────
    handle /healthz {
        reverse_proxy gateway:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Agent routing — /agents/* ──────────────────────────────────────────
    handle /agents/* {
        reverse_proxy gateway:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Gateway API — /v1/* (OpenAI-compatible) ─────────────────────────
    handle /v1/* {
        reverse_proxy gateway:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /mcp/* {
        reverse_proxy gateway:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Backoffice routes: /admin/*, /auth/*, /dashboard/*, /scim/* ───────
    handle /admin/* {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /auth/* {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /dashboard/* {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /scim/* {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── User login page — /login (before catch-all) ────────────────────────
    handle /login {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Prometheus federation — admin-authenticated ─────────────────────────
    handle /metrics-federate* {
        basic_auth {
            # Populated at bootstrap from generated prometheus_password secret
            {env.PROMETHEUS_BASICAUTH_USER} {env.PROMETHEUS_BASICAUTH_HASH}
        }
        reverse_proxy prometheus:9090
    }

    # ── Open WebUI Socket.IO — WebSocket bypass forward_auth ─────────────
    handle /socket.io/* {
        reverse_proxy open-webui:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Open WebUI API — needs forward_auth for identity ──────────────────
    handle /api/* {
        request_header -X-Forwarded-User
        request_header -X-Forwarded-Name
        request_header -X-Forwarded-Groups

        forward_auth backoffice:8443 {
            uri /auth/verify
            copy_headers X-Forwarded-User X-Forwarded-Name

            @unauthorized status 401
            handle_response @unauthorized {
                redir * /login?next={http.request.uri} 302
            }
        }

        reverse_proxy open-webui:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Open WebUI — catch-all (pages, assets) ────────────────────────────
    handle {
        request_header -X-Forwarded-User
        request_header -X-Forwarded-Name
        request_header -X-Forwarded-Groups

        forward_auth backoffice:8443 {
            uri /auth/verify
            copy_headers X-Forwarded-User X-Forwarded-Name

            @unauthorized status 401
            handle_response @unauthorized {
                redir * /login?next={http.request.uri} 302
            }
        }

        reverse_proxy open-webui:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }
}

# Redirect HTTP → HTTPS
http://{env.YASHIGANI_TLS_DOMAIN} {
    redir https://{env.YASHIGANI_TLS_DOMAIN}{uri} permanent
}
