# Yashigani — Caddy TLS edge (Let's Encrypt / ACME mode)
# Set YASHIGANI_TLS_DOMAIN in your .env before starting.
# Caddy will auto-obtain and renew the certificate via ACME HTTP-01 or TLS-ALPN-01.
#
# Requirements:
#   - Port 80 and 443 reachable from the internet (HTTP-01 challenge)
#   - Or port 443 reachable (TLS-ALPN-01)
#   - YASHIGANI_TLS_DOMAIN must resolve to this server's public IP
#
# TLS policy: TLS 1.2 minimum, TLS 1.3 preferred.
# Cipher suites: Caddy defaults (ECDHE + AES-GCM / ChaCha20-Poly1305 only).
# HSTS: max-age 1 year, includeSubDomains.
# OCSP stapling: enabled automatically by Caddy.

{env.YASHIGANI_TLS_DOMAIN} {
    # ── TLS policy ──────────────────────────────────────────────────────────
    tls {
        protocols tls1.2 tls1.3
        # ACME email for expiry notifications (auto-configured from admin email)
        # Set CADDY_ACME_EMAIL in .env
    }

    # ── Security headers ────────────────────────────────────────────────────
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "no-referrer"
        -Server
    }

    # ── Gateway health check — /healthz ──────────────────────────────────
    handle /healthz {
        reverse_proxy gateway:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Agent routing — /agents/* ──────────────────────────────────────────
    handle /agents/* {
        reverse_proxy gateway:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Gateway API — /v1/* (OpenAI-compatible) ─────────────────────────
    handle /v1/* {
        reverse_proxy gateway:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /mcp/* {
        reverse_proxy gateway:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Backoffice routes: /admin/*, /auth/*, /dashboard/*, /scim/* ───────
    handle /admin/* {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /auth/* {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /dashboard/* {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /scim/* {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Prometheus federation — admin-authenticated ─────────────────────────
    handle /metrics-federate* {
        basic_auth {
            # Populated at bootstrap from generated prometheus_password secret
            {env.PROMETHEUS_BASICAUTH_USER} {env.PROMETHEUS_BASICAUTH_HASH}
        }
        reverse_proxy prometheus:9090
    }

    # ── Open WebUI — catch-all (served at root for SvelteKit compatibility) ──
    handle {
        request_header -X-Forwarded-User
        request_header -X-Forwarded-Name
        request_header -X-Forwarded-Groups

        forward_auth backoffice:8443 {
            uri /auth/verify
            copy_headers X-Forwarded-User X-Forwarded-Name

            @unauthorized status 401
            handle_response @unauthorized {
                redir * /admin/login?next={http.request.uri} 302
            }
        }

        reverse_proxy open-webui:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }
}

# Redirect HTTP → HTTPS
http://{env.YASHIGANI_TLS_DOMAIN} {
    redir https://{env.YASHIGANI_TLS_DOMAIN}{uri} permanent
}
