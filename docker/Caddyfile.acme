# Yashigani — Caddy TLS edge (Let's Encrypt / ACME mode)
# Set YASHIGANI_TLS_DOMAIN in your .env before starting.
# Caddy will auto-obtain and renew the certificate via ACME HTTP-01 or TLS-ALPN-01.
#
# Requirements:
#   - Port 80 and 443 reachable from the internet (HTTP-01 challenge)
#   - Or port 443 reachable (TLS-ALPN-01)
#   - YASHIGANI_TLS_DOMAIN must resolve to this server's public IP
#
# TLS policy: TLS 1.2 minimum, TLS 1.3 preferred.
# Key exchange: hybrid post-quantum (X25519+ML-KEM-768) with X25519 fallback.
# Cipher suites: Caddy defaults (ECDHE + AES-GCM / ChaCha20-Poly1305 only).
# HSTS: max-age 1 year, includeSubDomains.
# OCSP stapling: enabled automatically by Caddy.
#
# ── DDoS / Connection Protection ────────────────────────────────────────────
# These protections work with the standard Caddy image (no extra modules needed).
#
# Connection timeouts:
#   Idle connections closed at 120 s; read timeouts prevent slow-body attacks.
#   Configured in the global options block below.
#
# Request body size:
#   request_body max_size applied globally to every handle block.
#   The application layer enforces an additional 4 MB limit (GatewayConfig).
#
# Full WAF (Coraza/OWASP CRS):
#   Requires a custom Caddy build with the coraza-caddy module.
#   See docker/caddy/Caddyfile.waf for instructions and a reference config.
#   Standard Caddy image does NOT include WAF — this is documented in
#   docs/yashigani_install_config.md Section 26.

{
    # ── Connection timeouts (DoS/slow-loris mitigation) ─────────────────────
    servers {
        timeouts {
            read_body   10s
            read_header 5s
            write       30s
            idle        120s
        }
    }
}

{env.YASHIGANI_TLS_DOMAIN} {
    # ── TLS policy ──────────────────────────────────────────────────────────
    tls {
        protocols tls1.2 tls1.3
        # Hybrid post-quantum key exchange: X25519+ML-KEM-768 preferred,
        # X25519 fallback for clients that don't support ML-KEM.
        # Protects against "Harvest Now, Decrypt Later" (HNDL) attacks.
        curves x25519mlkem768 x25519
    }

    # ── Security headers ────────────────────────────────────────────────────
    # Browser security features expected by Yashigani:
    # - HSTS: Strict-Transport-Security enforced (preload-ready)
    # - CSP: Content-Security-Policy with strict directives
    # - X-Content-Type-Options: nosniff (prevents MIME sniffing)
    # - X-Frame-Options: DENY (prevents clickjacking)
    # - COOP: Cross-Origin-Opener-Policy: same-origin
    # - Referrer-Policy: no-referrer
    # Fallback: if a browser lacks these features, Yashigani's
    # server-side controls (OPA, session validation, CSRF via SameSite)
    # provide equivalent protection without client-side enforcement.
    header {
        Strict-Transport-Security  "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options     "nosniff"
        X-Frame-Options            "DENY"
        Referrer-Policy            "no-referrer"
        Content-Security-Policy    "default-src 'self'; object-src 'none'; base-uri 'none'; report-uri /admin/csp-report; report-to default"
        Cross-Origin-Opener-Policy "same-origin"
        # Product / fingerprint hygiene (Ava Wave 2 observations 5 + 6):
        # strip Server, Via (reveals reverse-proxy product to Shodan) and
        # Alt-Svc (Caddy advertises HTTP/3 on :443 by default even when the
        # edge is bound to :8443 externally — misdirection for clients).
        -Server
        -Via
        -Alt-Svc
    }

    # ── Request body size limit (OWASP ASVS 4.1.7) ──────────────────────────
    # Hard ceiling at Caddy layer — prevents large-body DoS before the request
    # reaches the application.  Application layer enforces a tighter 4 MB limit.
    request_body {
        max_size 10MB
    }

    # ── RFC 9116 security.txt — vulnerability disclosure ──────────────────
    # Standard location for security researchers to find our contact + policy.
    # Responds directly from Caddy (no upstream needed). Operators may override
    # this block with a longer policy or an extra Contact line per deployment.
    handle /.well-known/security.txt {
        header Content-Type "text/plain; charset=utf-8"
        respond `Contact: mailto:security@agnosticsec.com
Contact: https://github.com/agnostic-security/yashigani/security/advisories/new
Expires: 2027-04-22T00:00:00Z
Preferred-Languages: en
Policy: https://agnosticsec.com/security
Hiring: https://agnosticsec.com/careers
` 200
    }

    # ── Gateway health check — /healthz ──────────────────────────────────
    handle /healthz {
        reverse_proxy gateway:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Agent routing — /agents/* ──────────────────────────────────────────
    handle /agents/* {
        reverse_proxy gateway:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Gateway API — /v1/* (OpenAI-compatible) ─────────────────────────
    handle /v1/* {
        reverse_proxy gateway:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /mcp/* {
        reverse_proxy gateway:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Backoffice routes: /admin/*, /auth/*, /dashboard/*, /scim/* ───────
    handle /admin/* {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /auth/* {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /dashboard/* {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /scim/* {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Grafana — admin-authenticated access via /admin/grafana/* ──────────
    handle_path /admin/grafana/* {
        forward_auth backoffice:8443 {
            uri /auth/verify
            @unauthorized status 401
            handle_response @unauthorized {
                redir * /admin/login?next=/admin/grafana/ 302
            }
        }
        reverse_proxy grafana:3000 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Wazuh Dashboard — admin-authenticated access via /admin/wazuh/* ────
    handle_path /admin/wazuh/* {
        forward_auth backoffice:8443 {
            uri /auth/verify
            @unauthorized status 401
            handle_response @unauthorized {
                redir * /admin/login 302
            }
        }
        reverse_proxy wazuh-dashboard:5601 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Prometheus — admin-authenticated access via /admin/prometheus/* ───
    handle_path /admin/prometheus/* {
        forward_auth backoffice:8443 {
            uri /auth/verify
            @unauthorized status 401
            handle_response @unauthorized {
                redir * /admin/login 302
            }
        }
        reverse_proxy prometheus:9090 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Static assets — public, no auth required (CSS/JS for admin UI) ────
    handle /static/* {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── User login page — /login (before catch-all) ────────────────────────
    handle /login {
        reverse_proxy backoffice:8443 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Prometheus federation — admin-authenticated ─────────────────────────
    handle /metrics-federate* {
        basic_auth {
            # Populated at bootstrap from generated prometheus_password secret
            {env.PROMETHEUS_BASICAUTH_USER} {env.PROMETHEUS_BASICAUTH_HASH}
        }
        reverse_proxy prometheus:9090
    }

    # ── Open WebUI — catch-all (served at root for SvelteKit compatibility) ──
    handle {
        request_header -X-Forwarded-User
        request_header -X-Forwarded-Name
        request_header -X-Forwarded-Groups

        forward_auth backoffice:8443 {
            uri /auth/verify
            copy_headers X-Forwarded-User X-Forwarded-Name

            @unauthorized status 401
            handle_response @unauthorized {
                redir * /login?next={http.request.uri} 302
            }
        }

        reverse_proxy open-webui:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }
}

# Redirect HTTP → HTTPS
http://{env.YASHIGANI_TLS_DOMAIN} {
    redir https://{env.YASHIGANI_TLS_DOMAIN}{uri} permanent
}
