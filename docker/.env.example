# Yashigani v2.23.1 — Environment variable template
# Last updated: 2026-04-28T16:59:30+01:00
#
# Copy to docker/.env and fill in required values:
#   cp docker/.env.example docker/.env
#
# Required variables are marked REQUIRED. Optional variables show their
# default value in the comment. Resource limits are env-overridable per
# YSG-RISK-004 (CWE-400).

# ---------------------------------------------------------------------------
# REQUIRED: Core configuration
# ---------------------------------------------------------------------------

# Public domain for TLS. Used by Caddy for ACME (Let's Encrypt).
YASHIGANI_TLS_DOMAIN=yashigani.example.com

# Upstream MCP server URL (the service Yashigani proxies to).
UPSTREAM_MCP_URL=https://your-mcp-server.example.com

# ---------------------------------------------------------------------------
# REQUIRED (generated by install.sh — do not set manually)
# ---------------------------------------------------------------------------

# Postgres password for the yashigani_app user.
# install.sh generates and writes this automatically.
POSTGRES_PASSWORD=

# URL-encoded version of POSTGRES_PASSWORD (% chars encoded as %25, etc.).
# Required for the DSN connection string. install.sh writes both.
POSTGRES_PASSWORD_URLENC=

# Open WebUI JWT secret key. install.sh generates a 64-char random value.
OWUI_SECRET_KEY=

# Prometheus basic-auth password hash (bcrypt). install.sh generates this.
PROMETHEUS_BASICAUTH_HASH=

# ---------------------------------------------------------------------------
# OPTIONAL: Runtime and deployment
# ---------------------------------------------------------------------------

# Deployment stream. Default: opensource. Options: opensource | enterprise
YASHIGANI_ENV=development
# YASHIGANI_DEPLOYMENT_STREAM=opensource

# TLS mode. Default: acme (Let's Encrypt). Options: acme | ca | selfsigned
# YASHIGANI_TLS_MODE=acme

# Host port mappings for Caddy
# YASHIGANI_HTTP_PORT=80
# YASHIGANI_HTTPS_PORT=443

# Ollama model to pull on first boot (digest-verified by ollama-init)
# OLLAMA_MODEL=qwen2.5:3b
# OLLAMA_MODEL_DIGEST=357c53fb659c

# PII detection mode. Default: log. Options: log | redact | block
# YASHIGANI_PII_MODE=log
# YASHIGANI_PII_CLOUD_BYPASS=false

# SSO / OIDC configuration (up to 10 IdPs)
# YASHIGANI_IDP_1_ID=
# YASHIGANI_IDP_1_NAME=
# YASHIGANI_IDP_1_PROTOCOL=
# YASHIGANI_IDP_1_DISCOVERY_URL=
# YASHIGANI_IDP_1_CLIENT_ID=
# YASHIGANI_IDP_1_CLIENT_SECRET=
# YASHIGANI_IDP_1_EMAIL_DOMAINS=
# YASHIGANI_IDP_1_REDIRECT_URI=

# Seccomp / AppArmor overrides (advanced — override only if your host kernel
# rejects the default profiles)
# YASHIGANI_SECCOMP_PROFILE=./seccomp/yashigani.json
# YASHIGANI_APPARMOR_PROFILE=yashigani-gateway

# Wazuh SIEM (opt-in via --profile wazuh)
# WAZUH_INDEXER_PASSWORD=
# WAZUH_API_PASSWORD=
# WAZUH_DASHBOARD_PASSWORD=

# Keycloak test IdP (opt-in via --profile test-idp — dev only)
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# RESOURCE LIMITS — YSG-RISK-004 (CWE-400)
# ---------------------------------------------------------------------------
# All service mem_limit and cpus values are env-overridable. Defaults below
# match the sizing baseline from the risk register / retro #3au.
# Adjust for your host capacity before running docker compose up -d.
#
# Units: mem_limit in Docker format (m = MiB, g = GiB), cpus as fractional cores.
# ---------------------------------------------------------------------------

# Core data plane
YASHIGANI_GATEWAY_MEM_LIMIT=1024m
YASHIGANI_GATEWAY_CPU_LIMIT=1.0
YASHIGANI_BACKOFFICE_MEM_LIMIT=1024m
YASHIGANI_BACKOFFICE_CPU_LIMIT=1.0

# TLS edge proxy
YASHIGANI_CADDY_MEM_LIMIT=256m
YASHIGANI_CADDY_CPU_LIMIT=0.5

# Policy engine (OPA)
YASHIGANI_POLICY_MEM_LIMIT=256m
YASHIGANI_POLICY_CPU_LIMIT=0.25

# Session + rate-limit stores
YASHIGANI_REDIS_MEM_LIMIT=256m
YASHIGANI_REDIS_CPU_LIMIT=0.25
YASHIGANI_BUDGET_REDIS_MEM_LIMIT=256m
YASHIGANI_BUDGET_REDIS_CPU_LIMIT=0.25

# Database
YASHIGANI_POSTGRES_MEM_LIMIT=1024m
YASHIGANI_POSTGRES_CPU_LIMIT=1.0
YASHIGANI_PGBOUNCER_MEM_LIMIT=256m
YASHIGANI_PGBOUNCER_CPU_LIMIT=0.25

# LLM inference (increase on GPU hosts with more VRAM)
YASHIGANI_OLLAMA_MEM_LIMIT=4096m
YASHIGANI_OLLAMA_CPU_LIMIT=2.0
YASHIGANI_OLLAMA_INIT_MEM_LIMIT=256m
YASHIGANI_OLLAMA_INIT_CPU_LIMIT=0.25

# Observability stack
YASHIGANI_PROMETHEUS_MEM_LIMIT=1024m
YASHIGANI_PROMETHEUS_CPU_LIMIT=0.5
YASHIGANI_GRAFANA_MEM_LIMIT=512m
YASHIGANI_GRAFANA_CPU_LIMIT=0.25
YASHIGANI_LOKI_MEM_LIMIT=512m
YASHIGANI_LOKI_CPU_LIMIT=0.25
YASHIGANI_PROMTAIL_MEM_LIMIT=256m
YASHIGANI_PROMTAIL_CPU_LIMIT=0.25
YASHIGANI_ALERTMANAGER_MEM_LIMIT=256m
YASHIGANI_ALERTMANAGER_CPU_LIMIT=0.25
YASHIGANI_OTEL_COLLECTOR_MEM_LIMIT=512m
YASHIGANI_OTEL_COLLECTOR_CPU_LIMIT=0.5
YASHIGANI_JAEGER_MEM_LIMIT=512m
YASHIGANI_JAEGER_CPU_LIMIT=0.5

# Optional: Open WebUI (--profile openwebui). Retro #3ag — OOMKilled at 512m.
YASHIGANI_OPENWEBUI_MEM_LIMIT=2048m
YASHIGANI_OPENWEBUI_CPU_LIMIT=1.0

# Optional: Agent bundles (--profile langflow/letta/openclaw)
YASHIGANI_LANGFLOW_MEM_LIMIT=1024m
YASHIGANI_LANGFLOW_CPU_LIMIT=1.0
YASHIGANI_LETTA_MEM_LIMIT=1024m
YASHIGANI_LETTA_CPU_LIMIT=1.0
YASHIGANI_OPENCLAW_MEM_LIMIT=1024m
YASHIGANI_OPENCLAW_CPU_LIMIT=1.0

# Optional: Wazuh SIEM (--profile wazuh)
YASHIGANI_WAZUH_MANAGER_MEM_LIMIT=1024m
YASHIGANI_WAZUH_MANAGER_CPU_LIMIT=1.0
YASHIGANI_WAZUH_INDEXER_MEM_LIMIT=1024m
YASHIGANI_WAZUH_INDEXER_CPU_LIMIT=1.0
YASHIGANI_WAZUH_DASHBOARD_MEM_LIMIT=1024m
YASHIGANI_WAZUH_DASHBOARD_CPU_LIMIT=1.0

# Optional: step-ca internal CA (--profile internal-ca)
YASHIGANI_STEP_CA_MEM_LIMIT=256m
YASHIGANI_STEP_CA_CPU_LIMIT=0.25

# Optional: Keycloak test IdP (--profile test-idp — dev only)
YASHIGANI_KEYCLOAK_MEM_LIMIT=1024m
YASHIGANI_KEYCLOAK_CPU_LIMIT=1.0

# Optional: Vault dev-mode KMS (--profile vault)
YASHIGANI_VAULT_MEM_LIMIT=512m
YASHIGANI_VAULT_CPU_LIMIT=0.5
