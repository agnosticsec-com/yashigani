{
  "realm": "yashigani-test",
  "displayName": "Yashigani Test Realm",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,

  "groups": [
    {
      "name": "engineers",
      "path": "/engineers"
    },
    {
      "name": "analysts",
      "path": "/analysts"
    },
    {
      "name": "admins",
      "path": "/admins"
    }
  ],

  "users": [
    {
      "username": "alice",
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Engineer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "groups": ["/engineers"]
    },
    {
      "username": "bob",
      "email": "bob@example.com",
      "firstName": "Bob",
      "lastName": "Analyst",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "groups": ["/analysts"]
    },
    {
      "username": "carol",
      "email": "carol@example.com",
      "firstName": "Carol",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "groups": ["/admins"]
    }
  ],

  "clients": [
    {
      "clientId": "yashigani",
      "name": "Yashigani OIDC Client",
      "description": "Confidential OIDC client for Yashigani identity broker (test only)",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "yashigani-test-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "publicClient": false,
      "frontchannelLogout": true,
      "protocol": "openid-connect",
      "redirectUris": [
        "https://*/auth/sso/oidc/*/callback",
        "http://localhost:*/auth/sso/oidc/*/callback"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "post.logout.redirect.uris": "+"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "given name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "firstName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "given_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "family name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "lastName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "family_name",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "yashigani-saml",
      "name": "Yashigani SAML Client",
      "description": "SAML 2.0 SP for Yashigani identity broker (test only)",
      "enabled": true,
      "protocol": "saml",
      "frontchannelLogout": true,
      "attributes": {
        "saml.authnstatement": "true",
        "saml.client.signature": "false",
        "saml.force.post.binding": "true",
        "saml.multivalued.roles": "false",
        "saml.server.signature": "true",
        "saml.server.signature.keyinfo.ext": "false",
        "saml.signature.algorithm": "RSA_SHA256",
        "saml.signing.certificate": "",
        "saml_assertion_consumer_url_post": "http://localhost:8080/auth/sso/saml/yashigani-test/acs",
        "saml_assertion_consumer_url_redirect": "",
        "saml_single_logout_service_url_post": "",
        "saml_single_logout_service_url_redirect": ""
      },
      "redirectUris": [
        "http://localhost:*/auth/sso/saml/*/acs",
        "https://*/auth/sso/saml/*/acs"
      ],
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": {
            "attribute.nameformat": "urn:oasis:names:tc:SAML:2.0:attrname-format:basic",
            "user.attribute": "email",
            "attribute.name": "email"
          }
        },
        {
          "name": "groups",
          "protocol": "saml",
          "protocolMapper": "saml-group-idp-mapper",
          "consentRequired": false,
          "config": {
            "attribute.nameformat": "urn:oasis:names:tc:SAML:2.0:attrname-format:basic",
            "attribute.name": "groups",
            "single": "false"
          }
        }
      ]
    }
  ],

  "clientScopes": [
    {
      "name": "groups",
      "description": "Adds group membership to tokens",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],

  "defaultDefaultClientScopes": [
    "role_list",
    "profile",
    "email",
    "roles",
    "web-origins",
    "acr",
    "groups"
  ],

  "defaultOptionalClientScopes": [
    "offline_access",
    "address",
    "phone",
    "microprofile-jwt"
  ]
}
