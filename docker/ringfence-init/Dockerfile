# Yashigani ringfence-init — L1 network-plane containment sidecar
#
# PURPOSE
#   Init-sidecar that applies a default-deny OUTPUT iptables/ip6tables policy
#   to the agent's network namespace, with a single ACCEPT to the resolved
#   Caddy IP on port 443. Runs to completion; the agent container starts
#   (depends_on: service_completed_successfully) only after this exits 0.
#
# DESIGN (plan §2.D L1-L8 + CRIT-01/02/03)
#   L1 — network-plane default-deny egress: iptables OUTPUT DROP with ACCEPT
#        to Caddy-IP:443 only. IPv6 disabled at compose level
#        (sysctls: net.ipv6.conf.all.disable_ipv6=1) + ip6tables DROP as
#        defence-in-depth (CRIT-03).
#   L2 — Caddy IP resolved via `getent hosts caddy` BEFORE the DROP rule is
#        active, so init containers running sequentially (K8s, compose init-
#        ordering) cannot race the resolver (CRIT-02).
#   K8s — NET_ADMIN is dropped by Kyverno's ClusterPolicy; a per-agent
#        PolicyException scoped to `yashigani.io/ringfence-init: "true"` is
#        generated by codegen alongside each agent manifest (L1).
#
# ROOTLESS-PODMAN GAP (plan L4 / HIGH-01)
#   iptables inside a rootless Podman user-namespace requires either
#   --privileged or SYS_ADMIN (not granted here). The script detects failure
#   and exits non-zero with a clear diagnostic. The compose codegen emits a
#   WARN in the generated docker-compose.override.yml stanza:
#     # ROOTLESS-PODMAN-L1-GAP: ringfence-init iptables will fail; L2+L3 only.
#   Rootless Podman deployments rely on L2 (Caddy egress enforcement) and
#   L3 (OPA policy) only. This is documented, not silently swallowed.
#
# SECURITY CONTEXT
#   - Base: alpine:3.21.3 (digest-pinned below; re-pin when Alpine cuts 3.22)
#   - Packages: iptables, ip6tables (via iptables metapackage), bind-tools
#     (getent via nss_dns), iproute2-minimal (ip addr for diagnostics only)
#   - Non-root target: the script needs NET_ADMIN to manipulate iptables in the
#     shared network namespace. NET_ADMIN cannot be exercised by a non-root UID
#     in an unshared user namespace. We run as UID 0 ONLY for the init phase
#     (write network rules), then the agent container runs non-root. The init
#     sidecar is NOT a long-running process — it exits after rule installation.
#   - ALL other capabilities dropped (cap_drop: [ALL] + cap_add: [NET_ADMIN]).
#   - No writeable filesystem beyond /tmp (tmpfs). readOnlyRootFilesystem: true
#     in K8s securityContext (Kyverno policy, with NET_ADMIN PolicyException).
#   - No secrets mounted. No network access during init (rules not yet set).
#   - Image is digest-pinned; SHA updated by Captain on each Alpine security
#     release. Never use floating tags.
#
# BUILD (DEFERRED — no runtime available; image must be built + pushed before
# the compose/helm codegen can reference a digest-pinned tag)
#   Build context: docker/ringfence-init/ (self-contained; no repo-root COPY)
#   docker buildx build \
#     --platform linux/amd64,linux/arm64 \
#     --tag ghcr.io/agnosticsec/ringfence-init:0.1.0 \
#     --push \
#     docker/ringfence-init/
#   After push: docker manifest inspect ghcr.io/agnosticsec/ringfence-init:0.1.0
#   Pin the returned digest in docker-compose.yml and helm/values.yaml as:
#     image: ghcr.io/agnosticsec/ringfence-init:0.1.0@sha256:<digest>
#
# LIVE-TEST PLAN (DEFERRED — needs runtime)
#   See docker/ringfence-init/README.md §"Deferred live-test plan".

# Alpine 3.21.3 — digest-pinned. Update with:
#   docker manifest inspect docker.io/library/alpine:3.21.3 \
#     | jq -r '.manifests[] | select(.platform.architecture=="amd64") | .digest'
# Re-pin for each architecture at buildx time via --platform flag.
# TODO(captain,post-runtime): pin digest after first manifest inspect.
FROM docker.io/library/alpine:3.21.3

# Install iptables (nf_tables shim on Alpine 3.21 — semantically equivalent
# to legacy iptables for OUTPUT chain manipulation), ip6tables (same package),
# and bind-tools for getent(1) / nss_dns hostname resolution.
# iproute2-minimal: ip addr/route for diagnostic output only.
# No shells beyond sh (busybox), no curl/wget, no package managers retained.
RUN apk add --no-cache \
    iptables=1.8.11-r1 \
    bind-tools \
    iproute2-minimal \
    # TODO(captain,post-runtime): pin bind-tools + iproute2-minimal versions.
    # Run `apk info bind-tools iproute2-minimal` inside a live alpine:3.21.3
    # container to get exact versions, then replace the lines above with:
    #   bind-tools=<version>
    #   iproute2-minimal=<version>
    # to match the iptables pinning already in place. Do NOT guess versions.
    && rm -rf /var/cache/apk/*

# Copy and lock the entrypoint script.
# 0755 root:root — readable+executable by root (our init UID).
# The script sets +x itself for clarity; Dockerfile chmod is the authoritative set.
COPY ringfence-init.sh /usr/local/bin/ringfence-init.sh
RUN chmod 0755 /usr/local/bin/ringfence-init.sh

# No USER directive: we intentionally run as UID 0 for the iptables init phase.
# This is the ONLY container in the stack that runs as root — justified because
# iptables manipulation in the network namespace requires CAP_NET_ADMIN, which
# Linux only honours for UID 0 in a non-user-namespaced context. The init
# container exits after rule installation; the agent container it initialises
# for runs non-root (enforced by Kyverno ClusterPolicy + compose hardening).
# cap_drop: [ALL] + cap_add: [NET_ADMIN] are set in the compose/K8s stanza,
# NOT baked here (avoids Docker default-caps confusion at build time).

ENTRYPOINT ["/usr/local/bin/ringfence-init.sh"]
