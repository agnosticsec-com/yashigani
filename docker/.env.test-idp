# Test IdP configuration — use with:
#   docker compose --profile test-idp --env-file docker/.env.test-idp up -d
#
# WARNING: These are dev-only credentials. Never use in production.
# The Keycloak instance is internal-network only (no external port exposure).

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# OIDC discovery URL for Yashigani to locate the test IdP endpoints
YASHIGANI_TEST_IDP_OIDC_DISCOVERY=http://keycloak:8080/realms/yashigani-test/.well-known/openid-configuration

# Client credentials matching the realm import (yashigani-test-realm.json)
YASHIGANI_TEST_IDP_CLIENT_ID=yashigani
YASHIGANI_TEST_IDP_CLIENT_SECRET=yashigani-test-secret
