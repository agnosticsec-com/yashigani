# Yashigani — Caddy TLS edge (self-signed certificate mode)
# Last updated: 2026-04-29T17:45:00+01:00
#
# ╔══════════════════════════════════════════════════════════╗
# ║  WARNING: SELF-SIGNED MODE — LOCAL / DEMO USE ONLY      ║
# ║  Browsers will show a certificate warning.               ║
# ║  DO NOT use in production or with real credentials.      ║
# ╚══════════════════════════════════════════════════════════╝
#
# Caddy generates a self-signed certificate automatically for localhost
# and any IP address. No setup required.
#
# ── DDoS / Connection Protection ────────────────────────────────────────────
# See Caddyfile.acme header comment for full explanation.
# Full WAF requires a custom Caddy build — see docker/caddy/Caddyfile.waf.

{
    # Use Caddy's internal CA for self-signed certs (no ACME)
    local_certs

    # ── Connection timeouts (DoS/slow-loris mitigation) ─────────────────────
    servers {
        timeouts {
            read_body   10s
            read_header 5s
            write       30s
            idle        120s
        }
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# Internal mTLS snippet — imported by every reverse_proxy / forward_auth block
# that targets a service terminating mTLS (gateway:8080, backoffice:8443).
# Caddy presents its own client cert and verifies the peer against the
# internal intermediate CA (Pattern B). The caddy_client.{crt,key} are minted
# by install.sh via yashigani.pki.issuer.
# ─────────────────────────────────────────────────────────────────────────────
(internal-mtls) {
    transport http {
        tls
        tls_trusted_ca_certs /run/secrets/ca_intermediate.crt
        tls_client_auth /run/secrets/caddy_client.crt /run/secrets/caddy_client.key
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# Layer B — Caddy HMAC shared-secret marker (EX-231-10 Layer B).
# Last updated: 2026-04-29T16:04:58+01:00
#
# DESIGN DECISION (2026-04-29):
#   Standard caddy:2-alpine has NO inline HMAC computation capability.
#   `caddy list-modules` confirms: no hmac/crypto/sign modules. A custom build
#   would be required for HMAC-SHA256 inline computation. Per Tiago directive
#   "Caddy-centric with hardening cryptography in communications" the pragmatic
#   fallback is:
#
#   Caddy reads /run/secrets/caddy_internal_hmac (32-byte hex, install-time
#   generated) and forwards it verbatim as X-Caddy-Verified-Secret on every
#   reverse_proxy to backoffice:8443 and gateway:8080.
#
#   Tom's middleware (follow-on dispatch) reads the same secret from
#   /run/secrets/caddy_internal_hmac at lifespan startup and verifies:
#     hmac.compare_digest(
#         request.headers["X-Caddy-Verified-Secret"],
#         stored_secret
#     )
#   Requests without a matching header → 401.
#
#   SECURITY PROPERTY: A data-network attacker with a valid mTLS cert CAN
#   present the cert + forge X-SPIFFE-ID, but CANNOT know the per-install
#   HMAC secret (it lives only in /run/secrets/caddy_internal_hmac, readable
#   only by uid 1001 within Caddy, backoffice, and gateway containers).
#   Without the correct X-Caddy-Verified-Secret → 401 from Tom's middleware.
#
#   The secret is generated at install time (not per-boot) to survive Caddy
#   restarts without requiring backoffice/gateway restart. It is regenerated
#   on `install.sh --upgrade` and all three containers pick it up on their
#   next lifespan startup.
#
#   REPLAY PROTECTION: The secret itself is static per install. Replay is
#   accepted as the residual risk given the constraint that all three callers
#   must agree on a 30-second time window without an NTP-sync step in install.
#   Mitigating factors: the secret ONLY flows on the internal mTLS mesh
#   (caddy_internal network), never on the external edge. An attacker able to
#   sniff caddy_internal has already broken mTLS — the secret adds defense-in-
#   depth, not primary authN.
#
# STRIP INBOUND: Drop any caller-supplied X-Caddy-Verified-Secret before
# setting our own. Prevents a data-network caller from forwarding a leaked
# secret value they captured from a previous request.
# ─────────────────────────────────────────────────────────────────────────────
(inject-caddy-verified) {
    # Strip any inbound value — only Caddy may set this header downstream.
    header_up -X-Caddy-Verified-Secret
    # Inject the per-install shared secret from the mounted secrets file.
    # {$CADDY_INTERNAL_HMAC} is a parse-time env substitution (NOT a request-time
    # placeholder). Caddy resolves this to the literal secret value when it parses
    # the Caddyfile on startup. {env.X} form does NOT work in header_up directives
    # (it is a request-time placeholder only valid in matchers/path expressions).
    # Round 1 failure (2026-04-29) root cause: {env.CADDY_INTERNAL_HMAC} shipped
    # the literal placeholder string instead of the secret value.
    header_up X-Caddy-Verified-Secret {$CADDY_INTERNAL_HMAC}
}

# Serve on HTTPS with self-signed cert
https://{env.YASHIGANI_TLS_DOMAIN}:443 {
    tls internal {
        protocols tls1.2 tls1.3
        # Hybrid post-quantum key exchange (HNDL protection)
        curves x25519mlkem768 x25519
        # V10.3.5 sender-constrained tokens: verify client cert if presented.
        # `verify_if_given` accepts non-mTLS browser connections AND extracts
        # SPIFFE URI from a presented client cert when one is given. Per-path
        # SPIFFE forwarding stays in handle blocks. Caddy v2 requires
        # client_auth at the server-block tls directive, not inside handle —
        # Captain #58c #3br evidence (2026-04-28).
        client_auth {
            mode verify_if_given
            trust_pool file /run/secrets/ca_intermediate.crt
        }
    }

    # Browser security features expected by Yashigani:
    # - HSTS: Strict-Transport-Security enforced (preload-ready)
    # - CSP: Content-Security-Policy with strict directives
    # - X-Content-Type-Options: nosniff (prevents MIME sniffing)
    # - X-Frame-Options: DENY (prevents clickjacking)
    # - COOP: Cross-Origin-Opener-Policy: same-origin
    # - Referrer-Policy: no-referrer
    # Fallback: if a browser lacks these features, Yashigani's
    # server-side controls (OPA, session validation, CSRF via SameSite)
    # provide equivalent protection without client-side enforcement.
    header {
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "no-referrer"
        Content-Security-Policy   "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'; report-uri /admin/csp-report; report-to default"
        Cross-Origin-Opener-Policy "same-origin"
        # Product / fingerprint hygiene (Ava Wave 2 observations 5 + 6).
        -Server
        -Via
        -Alt-Svc
    }

    # ── Request body size limit (OWASP ASVS 4.1.7) ──────────────────────────
    request_body {
        max_size 10MB
    }

    # ── RFC 9116 security.txt — vulnerability disclosure ──────────────────
    handle /.well-known/security.txt {
        header Content-Type "text/plain; charset=utf-8"
        respond `Contact: mailto:security@agnosticsec.com
Contact: https://github.com/agnostic-security/yashigani/security/advisories/new
Expires: 2027-04-22T00:00:00Z
Preferred-Languages: en
Policy: https://agnosticsec.com/security
Hiring: https://agnosticsec.com/careers
` 200
    }

    # ── Gateway health check — /healthz ──────────────────────────────────
    handle /healthz {
        reverse_proxy https://gateway:8080 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Agent routing — /agents/* ──────────────────────────────────────────
    # Site-level `tls internal { client_auth { ... } }` does the verify;
    # this handle just forwards SPIFFE URI from validated peer cert.
    handle /agents/* {
        request_header -X-SPIFFE-ID
        request_header X-SPIFFE-ID {http.request.tls.client.san.uris.0}
        reverse_proxy https://gateway:8080 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Gateway API — /v1/* (OpenAI-compatible) ─────────────────────────
    # Same as /agents/* — site-level client_auth, per-path SPIFFE forwarding.
    handle /v1/* {
        request_header -X-SPIFFE-ID
        request_header X-SPIFFE-ID {http.request.tls.client.san.uris.0}
        reverse_proxy https://gateway:8080 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── MCP proxy — /mcp/* ─────────────────────────────────────────────
    handle /mcp/* {
        reverse_proxy https://gateway:8080 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Backoffice routes: /admin/*, /auth/*, /dashboard/*, /scim/* ───────
    handle /admin/* {
        reverse_proxy https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /auth/* {
        reverse_proxy https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /dashboard/* {
        reverse_proxy https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /scim/* {
        reverse_proxy https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Grafana — admin-authenticated access via /admin/grafana/* ──────────
    handle_path /admin/grafana/* {
        forward_auth https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            uri /auth/verify
            @unauthorized status 401
            handle_response @unauthorized {
                redir * /admin/login?next=/admin/grafana/ 302
            }
        }
        reverse_proxy grafana:3000 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Wazuh Dashboard — admin-authenticated access via /admin/wazuh/* ────
    handle_path /admin/wazuh/* {
        forward_auth https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            uri /auth/verify
            @unauthorized status 401
            handle_response @unauthorized {
                redir * /admin/login 302
            }
        }
        reverse_proxy wazuh-dashboard:5601 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Prometheus — admin-authenticated access via /admin/prometheus/* ───
    handle_path /admin/prometheus/* {
        forward_auth https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            uri /auth/verify
            @unauthorized status 401
            handle_response @unauthorized {
                redir * /admin/login 302
            }
        }
        reverse_proxy prometheus:9090 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Static assets — public, no auth required (CSS/JS for admin UI) ────
    handle /static/* {
        reverse_proxy https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── User login page — /login (before catch-all) ────────────────────────
    handle /login {
        reverse_proxy https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /metrics-federate* {
        basic_auth {
            {env.PROMETHEUS_BASICAUTH_USER} {env.PROMETHEUS_BASICAUTH_HASH}
        }
        reverse_proxy prometheus:9090
    }

    # ── Open WebUI — catch-all (only active when --with-openwebui is used) ──
    # When Open WebUI is not deployed, Caddy returns 502 on / which is
    # acceptable — admin UI at /admin/ and API at /v1/ still work.
    handle {
        # Strip any externally-supplied identity headers (anti-spoofing)
        request_header -X-Forwarded-User
        request_header -X-Forwarded-Name
        request_header -X-Forwarded-Groups

        # Forward auth: validate session cookie against backoffice.
        # On 200: copies X-Forwarded-User/Name from response into the request.
        # On 401: redirects to login page.
        forward_auth https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            uri /auth/verify
            copy_headers X-Forwarded-User X-Forwarded-Name X-Forwarded-Email

            @unauthorized status 401
            handle_response @unauthorized {
                redir * /login?next={http.request.uri} 302
            }
        }

        reverse_proxy open-webui:8080 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
            # Explicitly pass the trusted identity headers from forward_auth
            header_up X-Forwarded-User {http.request.header.X-Forwarded-User}
            header_up X-Forwarded-Name {http.request.header.X-Forwarded-Name}
            header_up X-Forwarded-Email {http.request.header.X-Forwarded-Email}
        }
    }
}

# Also serve on HTTP for local convenience (self-signed mode only)
http://{env.YASHIGANI_TLS_DOMAIN}:80 {
    redir https://{env.YASHIGANI_TLS_DOMAIN}{uri} permanent
}

# ─────────────────────────────────────────────────────────────────────────────
# Internal observability listeners — :8444 gateway / :8445 backoffice.
# Mesh-internal only, never published to the host.
# Last updated: 2026-04-24T13:47:12+01:00
#
# Purpose:
#   Prometheus scrapes gateway/backoffice /internal/metrics through Caddy so
#   every scrape goes through our SPIFFE-aware identity gate. mTLS client-cert
#   auth is REQUIRED — Caddy refuses the TLS handshake without one.
#
# Per-port split (#81 fix):
#   Prometheus v3.x rejects setting `Host` via http_headers (forbidden). The
#   previous design used a single :8444 listener with a Host-header matcher
#   to pick gateway vs backoffice — that is incompatible with Prom v3. We
#   now give each upstream its own listener with identical semantics.
#
# Identity forwarding (EX-231-08, zero-trust default):
#   1. `request_header -X-SPIFFE-ID` strips any inbound value. Critical:
#      only Caddy may set this header downstream; an attacker co-located on
#      the internal bridge network who forged it would otherwise bypass the
#      application-layer ACL.
#   2. `request_header X-SPIFFE-ID {http.request.tls.client.san.uris.0}` sets
#      the header from the peer cert's first URI SAN. The peer cert was
#      minted by our internal CA (see yashigani.pki.issuer.build_leaf) with a
#      URI SAN of the form `spiffe://yashigani.internal/<service-name>`.
#   3. The upstream (gateway/backoffice) enforces the allowlist in
#      yashigani.auth.spiffe.require_spiffe_id against the parsed manifest.
#
# These listeners are NOT exposed in docker-compose.yml `ports:` — they are
# only reachable over the internal bridge network.
# ─────────────────────────────────────────────────────────────────────────────
:8444 {
    tls /run/secrets/caddy_client.crt /run/secrets/caddy_client.key {
        client_auth {
            mode require_and_verify
            trust_pool file /run/secrets/ca_intermediate.crt
        }
        protocols tls1.2 tls1.3
    }

    @metrics path /internal/metrics
    handle @metrics {
        # Spoof-prevention: drop any inbound X-SPIFFE-ID before setting our own.
        request_header -X-SPIFFE-ID
        # Populate from the verified peer cert's URI SAN.
        request_header X-SPIFFE-ID {http.request.tls.client.san.uris.0}

        reverse_proxy https://gateway:8080 {
            import internal-mtls
            import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # Default: reject anything else on this listener.
    handle {
        respond "Not Found" 404
    }
}

# Parallel listener for the backoffice upstream — identical SPIFFE gate,
# identical strip-before-set header discipline.
:8445 {
    tls /run/secrets/caddy_client.crt /run/secrets/caddy_client.key {
        client_auth {
            mode require_and_verify
            trust_pool file /run/secrets/ca_intermediate.crt
        }
        protocols tls1.2 tls1.3
    }

    @metrics path /internal/metrics
    handle @metrics {
        request_header -X-SPIFFE-ID
        request_header X-SPIFFE-ID {http.request.tls.client.san.uris.0}

        reverse_proxy https://backoffice:8443 {
            import internal-mtls
            import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle {
        respond "Not Found" 404
    }
}
