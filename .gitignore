# Python
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Yashigani runtime data
docker/secrets/
docker/.yashigani-install-state
# docker/var/ — per-install runtime state (service_identities populated with
# bootstrap_token_sha256 hashes, and future runtime artefacts).
# install.sh creates docker/var/runtime/service_identities.yaml on each run.
# This file must never be committed — it contains per-install token hashes.
docker/var/
data/*
docker/data/
*.log

# Model binaries — train locally, never commit
models/*.joblib

# License signing keys — NEVER commit private key
keys/
*.pem
scripts/keygen.py
scripts/sign_license.py

# cosign key pair — private key must never be committed
cosign.key

# Customer license files — do not commit
*.ysg

# Environment config — contains secrets
.env
.env.local

# TLS certificates
docker/tls/

# Alembic generated (keep versions/ in VCS)
src/yashigani/db/migrations/__pycache__/

# OS
**/.DS_Store
Thumbs.db

# IDE — editor-specific settings
.vscode/
.idea/

# Internal / agent memory — never publish
.claude/
prompt_logs/

# Internal testing — never commit
scripts/deploy-vm.sh
scripts/test-ui.py
.claude_agent_addendum.txt

# Compliance suite (product IP — not public)
scripts/owasp_prerelease_check.py
scripts/_asvs_*.py

# License signing (NEVER public)
scripts/sign_license.py
scripts/generate_license.py

# Backup data (contains secrets) — all contents ignored except .gitkeep.
# The directory must be tracked (via .gitkeep) so Podman rootless bind-mount
# does not fail on a missing host path (Docker auto-creates; Podman does not).
backups/*
!backups/.gitkeep

# Docker secrets (never commit)
docker/secrets/

# Any secret files
*.secret
*.pem
*.key
.claude-tmp/

# Internal operating notes for maintainer tooling — never commit
CLAUDE.md

# CI artifacts downloaded locally for smoke-test triage — never commit
ci-artifacts/

# Wazuh mTLS material generated at install time (admin cert/key, real-password configs) — never commit
docker/wazuh-mtls/
