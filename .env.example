# Yashigani v0.3.0 — environment configuration
# Copy to .env and fill in required values before running docker compose.
# Values marked GENERATED are set automatically at first-run bootstrap —
# do not set them manually unless restoring from backup.

# ── Core ────────────────────────────────────────────────────────────────────
YASHIGANI_ENV=production          # development | staging | production
YASHIGANI_VERSION=latest

# ── TLS ─────────────────────────────────────────────────────────────────────
YASHIGANI_TLS_MODE=acme           # acme | ca | selfsigned
YASHIGANI_TLS_DOMAIN=             # REQUIRED: FQDN e.g. yashigani.example.com
                                  # For selfsigned/local: localhost or 127.0.0.1

# ── Gateway ─────────────────────────────────────────────────────────────────
UPSTREAM_MCP_URL=                 # REQUIRED: target MCP server URL

# ── Admin / Backoffice ───────────────────────────────────────────────────────
# v0.2.0: admin username MUST be an email address
YASHIGANI_ADMIN_USERNAME=admin@example.com
# Admin password is auto-generated at first run and printed to stdout.
# Check: docker compose logs backoffice | grep -A 20 "FIRST-RUN"

# ── KSM ─────────────────────────────────────────────────────────────────────
YASHIGANI_KSM_PROVIDER=docker     # docker | keeper | aws | azure | gcp

# ── KSM rotation ────────────────────────────────────────────────────────────
KSM_ROTATION_SECRET_KEY=          # leave empty to disable auto-rotation
KSM_ROTATION_CRON=0 3 * * *       # minimum 1h interval enforced

# ── Redis ────────────────────────────────────────────────────────────────────
# Password is GENERATED at first-run bootstrap. Do not set manually.
# REDIS_PASSWORD=                 # GENERATED

# ── Ollama / Inspection ──────────────────────────────────────────────────────
OLLAMA_MODEL=qwen2.5:3b
YASHIGANI_INJECT_THRESHOLD=0.85   # 0.70–0.99
YASHIGANI_INSPECT_RESPONSES=false # Set true to inspect upstream responses (LLM05)

# ── Inspection Backend (v0.3.0) ───────────────────────────────────────────────
# Active backend: ollama | lmstudio | anthropic | azure_openai | gemini
# Defaults to ollama. Change via admin UI or PUT /admin/inspection/backend.
YASHIGANI_INSPECTION_DEFAULT_BACKEND=ollama
# Fallback chain (comma-separated, evaluated left-to-right on backend failure)
# "fail_closed" sentinel blocks all requests if all backends are unavailable.
YASHIGANI_INSPECTION_FALLBACK_CHAIN=ollama,gemini,fail_closed

# LM Studio (local, optional)
# LMSTUDIO_BASE_URL=http://localhost:1234   # or http://host.docker.internal:1234
# LMSTUDIO_MODEL=qwen2.5-3b-instruct

# Cloud inspection backends — API keys stored in KMS, not here.
# Register keys via admin UI: Admin → KMS → Add Secret
#   Key name: anthropic_api_key  → Anthropic Claude (claude-haiku-4-5 default)
#   Key name: azure_openai_key   → Azure OpenAI (gpt-4o-mini default)
#   Key name: gemini_api_key     → Google Gemini (gemini-1.5-flash default)
#
# Azure OpenAI requires endpoint and deployment name (no secrets):
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── Agent Routing (v0.3.0) ────────────────────────────────────────────────────
# Agents are registered via admin UI or POST /admin/agents.
# Bearer tokens are generated at registration and shown once — store securely.
# Token minimum length enforced at gateway:
YASHIGANI_AGENT_ROUTING_ENABLED=true
YASHIGANI_AGENT_PATH_PREFIX=/agents
YASHIGANI_AGENT_TOKEN_MIN_LENGTH=64

# ── Prometheus ───────────────────────────────────────────────────────────────
PROMETHEUS_RETENTION=30d
PROMETHEUS_BASICAUTH_USER=prometheus
# Hash is GENERATED at first-run bootstrap (bcrypt of prometheus_password secret).
# PROMETHEUS_BASICAUTH_HASH=      # GENERATED

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=grafana-admin
# Grafana admin password is GENERATED at first-run bootstrap.
# Check: docker compose logs backoffice | grep -A 20 "FIRST-RUN"

# ── Audit ────────────────────────────────────────────────────────────────────
YASHIGANI_AUDIT_MAX_FILE_SIZE_MB=100
YASHIGANI_AUDIT_RETENTION_DAYS=90
AUDIT_DATA_PATH=./data/audit

# ── Admin minimums ───────────────────────────────────────────────────────────
YASHIGANI_ADMIN_MIN_TOTAL=2
YASHIGANI_ADMIN_MIN_ACTIVE=2
YASHIGANI_ADMIN_SOFT_TARGET=3
YASHIGANI_USER_MIN_TOTAL=1

# ── PostgreSQL (v0.5.0) ────────────────────────────────────────────────────────
# DSN is auto-built from POSTGRES_PASSWORD secret at runtime.
# Override only if using an external Postgres instance.
# YASHIGANI_DB_DSN=postgresql://yashigani_app:PASSWORD@pgbouncer:5432/yashigani
# Postgres password is GENERATED at first-run bootstrap (scripts/bootstrap_postgres.py).
# POSTGRES_PASSWORD=                # GENERATED

# ── Deployment stream (v0.5.0) ────────────────────────────────────────────────
# opensource  — platform-wide JWKS only (no per-tenant JWT config)
# corporate   — per-tenant JWKS first, platform fallback
# saas        — per-tenant JWKS mandatory
YASHIGANI_DEPLOYMENT_STREAM=opensource

# ── JWT introspection (v0.5.0) ────────────────────────────────────────────────
# Platform-wide JWKS URL (used by opensource stream and as fallback for corporate).
# Leave empty to skip JWT validation when no bearer token is present.
# YASHIGANI_JWKS_URL=https://your-idp.example.com/.well-known/jwks.json
# YASHIGANI_JWT_ISSUER=https://your-idp.example.com
# YASHIGANI_JWT_AUDIENCE=yashigani-gateway

# ── HashiCorp Vault KMS (v0.5.0, opt-in profile) ─────────────────────────────
# Activate: docker compose --profile vault up -d
# AppRole credentials are stored in Docker secrets (vault_role_id, vault_secret_id).
# VAULT_ADDR=http://vault:8200

# ── OpenTelemetry (v0.5.0) ────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ── FastText classifier (v0.5.0) ──────────────────────────────────────────────
# Model bundled in gateway image. Override only if using a custom model.
FASTTEXT_MODEL_PATH=/app/models/fasttext_classifier.bin

# ── Response cache (v0.5.0) ───────────────────────────────────────────────────
# Max TTL enforced server-side regardless of per-request header.
# YASHIGANI_CACHE_MAX_TTL=3600

# ── SIEM integration (v0.5.0) ────────────────────────────────────────────────
# Configure via Admin → Audit → SIEM Integration panel.
# Wazuh self-hosted SIEM: docker compose -f docker-compose.yml -f docker-compose.wazuh.yml up -d
# Wazuh admin password is GENERATED on first run (36-char).
# Check: docker compose logs wazuh-manager | grep -A 10 "WAZUH CREDENTIALS"

# ── Alertmanager escalation (v0.5.0) ─────────────────────────────────────────
# Configure receivers in config/alertmanager.yml.
# Secrets (SMTP password, Twilio token, PagerDuty key) are mounted from /run/secrets.

# ── Per-endpoint rate limiting (v0.5.0) ───────────────────────────────────────
# Default limits apply to all endpoints. Override per-path via Admin → Rate Limiting.
# YASHIGANI_EP_RL_DEFAULT_WINDOW_SECONDS=60
# YASHIGANI_EP_RL_DEFAULT_MAX_CALLS=100

# ── Licensing (v0.6.0) ────────────────────────────────────────────────────────
# Community edition: no key required. Limits: 10 agents, 1 org, no SAML/OIDC/SCIM.
# Professional / Enterprise: provide a signed .ysg license file.
#
# Option A — file path:
# YASHIGANI_LICENSE_FILE=/path/to/license.ysg
#
# Option B — Docker secret (recommended for production):
#   Place license content in docker/secrets/license_key
#   The loader checks /run/secrets/license_key automatically.
#
# The installer wizard will copy your license file to the correct location.
# Leave unset to run as Community edition.
